<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GameSaves.App.ViewModels"
             xmlns:models="using:GameSaves.App.Models"
             x:Class="GameSaves.App.Views.SyncView"
             x:DataType="vm:SyncViewModel"
             Background="#111217">

    <UserControl.Resources>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1A1B22" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#2A2C36" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F4F4F5" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#A7AAB4" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#777B86" />
        <SolidColorBrush x:Key="AccentBrush" Color="#7C9CFF" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#6EE7A8" />
        <SolidColorBrush x:Key="WarningBrush" Color="#FACC6B" />

        <!-- Blend the Fluent Expander chrome into the card look: header and
             content share the card background instead of the theme's darker
             content band. -->
        <SolidColorBrush x:Key="ExpanderHeaderBackground" Color="#1A1B22" />
        <SolidColorBrush x:Key="ExpanderHeaderBackgroundPointerOver" Color="#20222B" />
        <SolidColorBrush x:Key="ExpanderHeaderBackgroundPressed" Color="#20222B" />
        <SolidColorBrush x:Key="ExpanderHeaderBorderBrush" Color="Transparent" />
        <SolidColorBrush x:Key="ExpanderContentBackground" Color="#1A1B22" />
        <SolidColorBrush x:Key="ExpanderContentBorderBrush" Color="#2A2C36" />
        <SolidColorBrush x:Key="ToggleButtonBackground" Color="Transparent" />
        <SolidColorBrush x:Key="ToggleButtonBackgroundPointerOver" Color="#20222B" />
        <SolidColorBrush x:Key="ToggleButtonBackgroundPressed" Color="#20222B" />
        <SolidColorBrush x:Key="ToggleButtonBackgroundChecked" Color="Transparent" />
        <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPointerOver" Color="#20222B" />
        <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPressed" Color="#20222B" />
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Expander">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="#1A1B22" />
            <Setter Property="BorderBrush" Value="#2A2C36" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="12,8" />
        </Style>

        <Style Selector="Expander /template/ ToggleButton#ExpanderHeader">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#F4F4F5" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style Selector="Expander /template/ Border#ExpanderContent">
            <Setter Property="Background" Value="#1A1B22" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*"
          RowSpacing="10"
          Margin="0,12,0,0">

        <!-- Header: always-visible controls and live progress -->
        <Border Grid.Row="0"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14,10">

            <StackPanel Spacing="6">
                <Grid ColumnDefinitions="*,Auto,Auto"
                      ColumnSpacing="10">

                    <StackPanel Grid.Column="0"
                                Spacing="2"
                                VerticalAlignment="Center">
                        <TextBlock Text="Sync Backups"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   FontSize="18"
                                   FontWeight="Bold" />

                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="Preview Sync (Dry Run)"
                            Command="{Binding PreviewSyncCommand}"
                            Height="34"
                            VerticalAlignment="Center" />

                    <Button Grid.Column="2"
                            Content="Sync Now"
                            Command="{Binding ExecuteSyncCommand}"
                            IsEnabled="{Binding CanExecuteSync}"
                            Height="34"
                            VerticalAlignment="Center" />
                </Grid>

                <StackPanel Orientation="Horizontal"
                            Spacing="16">
                    <CheckBox Content="Upload local runs"
                              IsChecked="{Binding UploadEnabled}"
                              FontSize="12" />

                    <CheckBox Content="Download remote runs"
                              IsChecked="{Binding DownloadEnabled}"
                              FontSize="12" />

                    <CheckBox Content="I understand this will copy backup runs"
                              IsChecked="{Binding ConfirmSync}"
                              FontSize="12" />
                </StackPanel>

                <StackPanel Spacing="2"
                            IsVisible="{Binding IsSyncRunning}">
                    <ProgressBar Minimum="0"
                                 Maximum="{Binding ProgressMax}"
                                 Value="{Binding ProgressValue}"
                                 Height="14" />

                    <TextBlock Text="{Binding ProgressText}"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="{Binding ProgressText}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Collapsible sections; the whole area scrolls as one -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="10">

                <!-- Sync target and connection -->
                <Expander Header="Sync target &amp; connection"
                          IsExpanded="{Binding TargetSectionExpanded}">

                    <StackPanel Spacing="6"
                                Margin="0,6,0,0">

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="10">
                            <TextBlock Grid.Column="0"
                                       Text="Remote profile"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="12" />

                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding RemoteProfiles}"
                                      SelectedItem="{Binding SelectedRemoteProfile}"
                                      MinHeight="32"
                                      PlaceholderText="Unsaved profile">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="10">
                            <TextBox Grid.Column="0"
                                     Text="{Binding RemoteProfileDisplayName}"
                                     PlaceholderText="Profile name, for example Home SFTP Server"
                                     MaxLength="100"
                                     MinHeight="32" />

                            <TextBlock Grid.Column="1"
                                       Text="{Binding RemoteProfileState}"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="12" />
                        </Grid>

                        <StackPanel Orientation="Horizontal"
                                    Spacing="6">
                            <Button Content="New"
                                    Command="{Binding NewRemoteProfileCommand}"
                                    Height="30" />
                            <Button Content="Save"
                                    Command="{Binding SaveRemoteProfileCommand}"
                                    Height="30" />
                            <Button Content="Save As"
                                    Command="{Binding SaveRemoteProfileAsCommand}"
                                    Height="30" />
                            <Button Content="Rename"
                                    Command="{Binding RenameRemoteProfileCommand}"
                                    Height="30" />
                            <Button Content="Delete"
                                    Command="{Binding DeleteRemoteProfileCommand}"
                                    Height="30" />
                        </StackPanel>

                        <CheckBox Content="Confirm deleting only the selected profile configuration"
                                  IsChecked="{Binding ConfirmDeleteRemoteProfile}"
                                  FontSize="11"
                                  ToolTip.Tip="Profile deletion never removes backup runs, remote files, sync history, ZIP archives, save files, or SFTP known-host entries." />

                        <Grid ColumnDefinitions="Auto,280"
                              ColumnSpacing="10">
                            <TextBlock Grid.Column="0"
                                       Text="Provider"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="12" />

                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding ProviderOptions}"
                                      SelectedValue="{Binding SelectedProviderKind}"
                                      SelectedValueBinding="{Binding Kind}"
                                      MinHeight="32">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>

                        <!-- Local folder target -->
                        <StackPanel Spacing="4"
                                    IsVisible="{Binding IsLocalFolderSelected}">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="6">

                                <TextBox Grid.Column="0"
                                         Text="{Binding RemoteRootPath}"
                                         Watermark="Folder to sync backup runs with (NAS share, USB drive, cloud-synced folder)"
                                         ToolTip.Tip="{Binding RemoteRootPath}"
                                         MinHeight="32" />

                                <Button Grid.Column="1"
                                        Content="Choose Folder..."
                                        Command="{Binding ChooseRemoteFolderCommand}"
                                        Height="32"
                                        VerticalAlignment="Top" />
                            </Grid>
                        </StackPanel>

                        <!-- SFTP target -->
                        <StackPanel Spacing="4"
                                    IsVisible="{Binding IsSftpSelected}">

                            <Grid ColumnDefinitions="2*,90,*"
                                  ColumnSpacing="6">

                                <TextBox Grid.Column="0"
                                         Text="{Binding SftpHost}"
                                         Watermark="Host name or IP address"
                                         MinHeight="30" />

                                <TextBox Grid.Column="1"
                                         Text="{Binding SftpPort}"
                                         Watermark="22"
                                         ToolTip.Tip="SSH port (default 22)"
                                         MinHeight="30" />

                                <TextBox Grid.Column="2"
                                         Text="{Binding SftpUsername}"
                                         Watermark="Username"
                                         MinHeight="30" />
                            </Grid>

                            <StackPanel Orientation="Horizontal"
                                        Spacing="14">
                                <RadioButton Content="Password"
                                             GroupName="SftpAuth"
                                             IsChecked="{Binding SftpUsePassword}"
                                             FontSize="12" />

                                <RadioButton Content="Private key file"
                                             GroupName="SftpAuth"
                                             IsChecked="{Binding SftpUsePrivateKey}"
                                             FontSize="12" />
                            </StackPanel>

                            <TextBox Text="{Binding SftpPassword}"
                                     PasswordChar="●"
                                     Watermark="Password (kept in memory only, never stored)"
                                     IsVisible="{Binding SftpUsePassword}"
                                     MinHeight="30" />

                            <StackPanel Spacing="4"
                                        IsVisible="{Binding SftpUsePrivateKey}">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="6">

                                    <TextBox Grid.Column="0"
                                             Text="{Binding SftpKeyFilePath}"
                                             Watermark="Path to the private key file (e.g. C:\Users\you\.ssh\id_ed25519)"
                                             ToolTip.Tip="{Binding SftpKeyFilePath}"
                                             MinHeight="30" />

                                    <Button Grid.Column="1"
                                            Content="Browse..."
                                            Command="{Binding ChooseKeyFileCommand}"
                                            Height="30"
                                            VerticalAlignment="Top" />
                                </Grid>

                                <TextBox Text="{Binding SftpKeyPassphrase}"
                                         PasswordChar="●"
                                         Watermark="Key passphrase, if any (kept in memory only, never stored)"
                                         MinHeight="30" />
                            </StackPanel>

                            <TextBox Text="{Binding SftpRemotePath}"
                                     Watermark="Remote folder path, e.g. /srv/gamesave-sync"
                                     MinHeight="30" />

                            <CheckBox Content="Trust this server's host key on first connect"
                                      IsChecked="{Binding SftpTrustNewHostKey}"
                                      FontSize="12"
                                      ToolTip.Tip="On the first connection the server's key fingerprint is stored (like SSH known_hosts). If it ever changes later, the sync fails loudly. Leave unchecked to see the fingerprint first without trusting it." />

                            <StackPanel Orientation="Horizontal"
                                        Spacing="10">
                                <Button Content="Forget Stored Host Key"
                                        Command="{Binding ForgetSftpHostKeyCommand}"
                                        FontSize="12"
                                        Height="28"
                                        ToolTip.Tip="Removes the stored fingerprint for this host and port, e.g. after a planned server reinstall." />

                                <TextBlock Text="Passwords and passphrases are never saved to disk."
                                           Foreground="{StaticResource WarningBrush}"
                                           FontSize="11"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>

                        <Button Content="Check Connection &amp; Sync Status"
                                Command="{Binding CheckSyncStatusCommand}"
                                Height="30"
                                FontSize="12"
                                Margin="0,4,0,0"
                                ToolTip.Tip="Connects to the sync target and reports whether the backup runs are in sync - without copying anything. Preview Sync (Dry Run) performs the same check automatically." />

                        <TextBlock Text="{Binding ConnectionCheckMessage}"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap" />

                        <TextBlock Text="Sync copies whole backup runs both ways. A run missing on one side is copied there - nothing is ever deleted or overwritten. Runs that differ on both sides are reported as conflicts and never copied automatically."
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Expander>

                <!-- Sync plan -->
                <Expander Header="Sync plan"
                          IsExpanded="{Binding PlanSectionExpanded}">

                    <StackPanel Spacing="4"
                                Margin="0,6,0,0">

                        <TextBlock Text="{Binding SummaryDisplay}"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap" />

                        <Grid ColumnDefinitions="*,Auto,Auto"
                              ColumnSpacing="8">

                            <TextBlock Grid.Column="0"
                                       Text="{Binding SelectedSummaryDisplay}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center" />

                            <Button Grid.Column="1"
                                    Content="Select All"
                                    Command="{Binding SelectAllRunsCommand}"
                                    FontSize="12"
                                    Height="26" />

                            <Button Grid.Column="2"
                                    Content="Select None"
                                    Command="{Binding DeselectAllRunsCommand}"
                                    FontSize="12"
                                    Height="26" />
                        </Grid>

                        <Border Padding="0,6,0,6"
                                BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="0,0,0,1">

                            <Grid ColumnDefinitions="34,2*,90,*,90,90,*"
                                  ColumnSpacing="10">

                                <TextBlock Grid.Column="0" Text="" />
                                <TextBlock Grid.Column="1" Text="Run" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" FontWeight="Bold" />
                                <TextBlock Grid.Column="2" Text="Action" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" FontWeight="Bold" />
                                <TextBlock Grid.Column="3" Text="Game" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" FontWeight="Bold" />
                                <TextBlock Grid.Column="4" Text="Files" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" FontWeight="Bold" />
                                <TextBlock Grid.Column="5" Text="Size" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" FontWeight="Bold" />
                                <TextBlock Grid.Column="6" Text="Status" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" FontWeight="Bold" />
                            </Grid>
                        </Border>

                        <ItemsControl ItemsSource="{Binding Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:SyncItemRowViewModel">
                                    <Border Padding="0,6"
                                            BorderBrush="#252733"
                                            BorderThickness="0,0,0,1">

                                        <Grid ColumnDefinitions="34,2*,90,*,90,90,*"
                                              ColumnSpacing="10">

                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IncludeInSync}"
                                                      IsVisible="{Binding IsSelectable}"
                                                      ToolTip.Tip="Untick to exclude this run from the sync." />

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding RunName}"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       ToolTip.Tip="{Binding RunName}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding ActionText}"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold" />

                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding GameName}"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />

                                            <TextBlock Grid.Column="4"
                                                       Text="{Binding FilesDisplay}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center" />

                                            <TextBlock Grid.Column="5"
                                                       Text="{Binding SizeDisplay}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center" />

                                            <TextBlock Grid.Column="6"
                                                       Text="{Binding StatusText}"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Expander>

                <!-- Warnings -->
                <Expander Header="Warnings"
                          IsExpanded="{Binding WarningsSectionExpanded}">

                    <ItemsControl ItemsSource="{Binding Warnings}"
                                  Margin="0,6,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:TransferWarningRowViewModel">
                                <Border Padding="0,6"
                                        BorderBrush="#252733"
                                        BorderThickness="0,0,0,1">

                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8">
                                        <TextBlock Text="{Binding SeverityText}"
                                                   Foreground="{StaticResource WarningBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Width="60" />

                                        <TextBlock Text="{Binding Message}"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>

                <!-- Execution results -->
                <Expander Header="Execution results"
                          IsExpanded="{Binding ResultsSectionExpanded}">

                    <StackPanel Spacing="4"
                                Margin="0,6,0,0">

                        <TextBlock Text="{Binding ExecutionStatusMessage}"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap" />

                        <ItemsControl ItemsSource="{Binding ExecutionResults}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:SyncItemResultRowViewModel">
                                    <Border Padding="0,6"
                                            BorderBrush="#252733"
                                            BorderThickness="0,0,0,1">

                                        <Grid ColumnDefinitions="2*,130,90,*"
                                              ColumnSpacing="10">

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding RunName}"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis" />

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Status}"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold" />

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding SizeDisplay}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="12" />

                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding Error}"
                                                       Foreground="{StaticResource WarningBrush}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Expander>

                <!-- Sync history -->
                <Expander Header="Sync history"
                          IsExpanded="{Binding HistorySectionExpanded}">

                    <StackPanel Spacing="4"
                                Margin="0,6,0,0">

                        <TextBlock Text="Every executed sync, from the log stored alongside the sync folder - shared by all devices syncing with it."
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap" />

                        <ItemsControl ItemsSource="{Binding SyncLog}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:SyncLogEntryRowViewModel">
                                    <Border Padding="0,6"
                                            BorderBrush="#252733"
                                            BorderThickness="0,0,0,1">

                                        <StackPanel Spacing="2">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="10">
                                                <TextBlock Text="{Binding TimestampDisplay}"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           FontSize="12" />

                                                <TextBlock Text="{Binding DeviceName}"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           FontSize="12" />

                                                <TextBlock Text="{Binding SummaryDisplay}"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           FontSize="12" />
                                            </StackPanel>

                                            <TextBlock Text="{Binding RunsDisplay}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       FontSize="10"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
