<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GameSaves.App.ViewModels"
             xmlns:models="using:GameSaves.App.Models"
             x:Class="GameSaves.App.Views.InstalledGamesView"
             x:DataType="vm:InstalledGamesViewModel">

    <Grid RowDefinitions="Auto,Auto,*"
          Margin="16"
          RowSpacing="12">

        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Spacing="12">

            <Button Content="Refresh Installed Games"
                    Command="{Binding RefreshCommand}" />

            <TextBlock Text="{Binding StatusMessage}"
                       VerticalAlignment="Center" />
        </StackPanel>

        <Border Grid.Row="1"
                Padding="8"
                BorderThickness="1">
            <Grid ColumnDefinitions="2*,90,2*,2*,100,100,100,100,100,120"
                  ColumnSpacing="8">
                <TextBlock Grid.Column="0" Text="Game" FontWeight="Bold" />
                <TextBlock Grid.Column="1" Text="AppID" FontWeight="Bold" />
                <TextBlock Grid.Column="2" Text="Install path" FontWeight="Bold" />
                <TextBlock Grid.Column="3" Text="Library" FontWeight="Bold" />
                <TextBlock Grid.Column="4" Text="Approved" FontWeight="Bold" />
                <TextBlock Grid.Column="5" Text="Pending" FontWeight="Bold" />
                <TextBlock Grid.Column="6" Text="NeedsFix" FontWeight="Bold" />
                <TextBlock Grid.Column="7" Text="Exists" FontWeight="Bold" />
                <TextBlock Grid.Column="8" Text="Files" FontWeight="Bold" />
                <TextBlock Grid.Column="9" Text="Status" FontWeight="Bold" />
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2">
            <ItemsControl ItemsSource="{Binding Games}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:InstalledGameRowViewModel">
                        <Border Padding="8"
                                BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="2*,90,2*,2*,100,100,100,100,100,120"
                                  ColumnSpacing="8">

                                <TextBlock Grid.Column="0"
                                           Text="{Binding GameName}"
                                           TextTrimming="CharacterEllipsis" />

                                <TextBlock Grid.Column="1"
                                           Text="{Binding AppId}" />

                                <TextBlock Grid.Column="2"
                                           Text="{Binding InstallPath}"
                                           TextTrimming="CharacterEllipsis" />

                                <TextBlock Grid.Column="3"
                                           Text="{Binding LibraryPath}"
                                           TextTrimming="CharacterEllipsis" />

                                <TextBlock Grid.Column="4"
                                           Text="{Binding ApprovedMappings}" />

                                <TextBlock Grid.Column="5"
                                           Text="{Binding PendingMappings}" />

                                <TextBlock Grid.Column="6"
                                           Text="{Binding NeedsFixMappings}" />

                                <TextBlock Grid.Column="7"
                                           Text="{Binding SavePathExists}" />

                                <StackPanel Grid.Column="8">
                                    <TextBlock Text="{Binding FileCount}" />
                                    <TextBlock Text="{Binding TotalSizeDisplay}"
                                               FontSize="11"
                                               Opacity="0.7" />
                                </StackPanel>

                                <TextBlock Grid.Column="9"
                                           Text="{Binding Status}"
                                           FontWeight="SemiBold" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>