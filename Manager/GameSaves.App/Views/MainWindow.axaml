<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GameSaves.App.ViewModels"
        x:Class="GameSaves.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Game Saves Manager"
        Width="900"
        Height="600">

	<StackPanel Margin="24" Spacing="12">
		<TextBlock Text="Game Saves Manager"
                   FontSize="28"
                   FontWeight="Bold" />

		<Button Content="Refresh"
                Command="{Binding RefreshCommand}"
                Width="160" />

		<TextBlock Text="{Binding StatusMessage}" />

		<Separator />

		<TextBlock Text="Foundation status"
                   FontSize="20"
                   FontWeight="SemiBold" />

		<Grid ColumnDefinitions="240,*"
              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
              RowSpacing="8"
              ColumnSpacing="16">

			<TextBlock Grid.Row="0" Grid.Column="0" Text="Database:" />
			<TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DatabasePath}" />

			<TextBlock Grid.Row="1" Grid.Column="0" Text="Platform:" />
			<TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Platform}" />

			<TextBlock Grid.Row="2" Grid.Column="0" Text="Steam root:" />
			<TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SteamRoot}" />

			<TextBlock Grid.Row="3" Grid.Column="0" Text="Libraries:" />
			<TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LibraryCount}" />

			<TextBlock Grid.Row="4" Grid.Column="0" Text="Installed games:" />
			<TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding InstalledGameCount}" />

			<TextBlock Grid.Row="5" Grid.Column="0" Text="Steam profiles:" />
			<TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SteamProfileCount}" />

			<TextBlock Grid.Row="6" Grid.Column="0" Text="Approved mappings:" />
			<TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding ApprovedMappingCount}" />

			<TextBlock Grid.Row="7" Grid.Column="0" Text="Pending / NeedsFix:" />
			<TextBlock Grid.Row="7" Grid.Column="1">
				<TextBlock.Text>
					<MultiBinding StringFormat="{}{0} pending, {1} needs fix">
						<Binding Path="PendingMappingCount" />
						<Binding Path="NeedsFixMappingCount" />
					</MultiBinding>
				</TextBlock.Text>
			</TextBlock>
		</Grid>
	</StackPanel>
</Window>