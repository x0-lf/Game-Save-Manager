<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GameSaves.App.ViewModels"
             xmlns:models="using:GameSaves.App.Models"
             x:Class="GameSaves.App.Views.TransferHistoryView"
             x:DataType="vm:TransferHistoryViewModel"
             Background="#111217">

    <UserControl.Resources>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1A1B22" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#2A2C36" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F4F4F5" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#A7AAB4" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#777B86" />
        <SolidColorBrush x:Key="AccentBrush" Color="#7C9CFF" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#6EE7A8" />
        <SolidColorBrush x:Key="WarningBrush" Color="#FACC6B" />
        <SolidColorBrush x:Key="SplitterBrush" Color="#2A2C36" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*"
          RowSpacing="10"
          Margin="0,12,0,0">

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14,10">

            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">

                <StackPanel Grid.Column="0"
                            Spacing="2">
                    <TextBlock Text="Run History"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               FontSize="18"
                               FontWeight="Bold" />

                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontSize="12"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Refresh History"
                        Command="{Binding RefreshRunsCommand}"
                        Height="34"
                        VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Runs / items (resizable) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" MinWidth="260" MaxWidth="640" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" MinWidth="380" />
            </Grid.ColumnDefinitions>

            <!-- Runs list -->
            <Border Grid.Column="0"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="0">

                <Grid RowDefinitions="Auto,*">

                    <Border Grid.Row="0"
                            Padding="12,8"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="0,0,0,1">

                        <StackPanel Spacing="2">
                            <TextBlock Text="Executed runs"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold" />

                            <TextBlock Text="Every transfer copy, restore, and manual backup is recorded here automatically."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Runs}"
                             SelectedItem="{Binding SelectedRun}"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:TransferRunRowViewModel">
                                <StackPanel Spacing="3"
                                            Margin="4">

                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8">
                                        <TextBlock Text="{Binding KindText}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontWeight="SemiBold"
                                                   FontSize="12" />

                                        <TextBlock Text="{Binding GameName}"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>

                                    <TextBlock Text="{Binding StartedDisplay}"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               FontSize="11" />

                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8">
                                        <TextBlock Text="{Binding ProfilesDisplay}"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="11" />

                                        <TextBlock Text="{Binding CountsDisplay}"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="11" />

                                        <TextBlock Text="{Binding BytesDisplay}"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="11" />
                                    </StackPanel>

                                    <TextBlock Text="{Binding FlagsDisplay}"
                                               Foreground="{StaticResource WarningBrush}"
                                               FontSize="11" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="8"
                          Margin="1,0"
                          Background="{StaticResource SplitterBrush}"
                          ResizeDirection="Columns" />

            <!-- Items of the selected run -->
            <Border Grid.Column="2"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="0">

                <Grid RowDefinitions="Auto,Auto,Auto,*">

                    <Border Grid.Row="0"
                            Padding="12,8"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="0,0,0,1">

                        <StackPanel Spacing="2">
                            <TextBlock Text="Files in this run"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold" />

                            <TextBlock Text="Exactly what was copied, skipped, or failed, per file."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Padding="12,6"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="0,0,0,1"
                            IsVisible="{Binding SelectedRun.WasBlocked, FallbackValue=False}">

                        <TextBlock Text="{Binding SelectedRun.BlockedReason, StringFormat='Run was blocked: {0}'}"
                                   Foreground="{StaticResource WarningBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                    </Border>

                    <Border Grid.Row="2"
                            Padding="10,6"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="0,0,0,1">

                        <Grid ColumnDefinitions="2*,2*,80,150,*"
                              ColumnSpacing="10">

                            <TextBlock Grid.Column="0"
                                       Text="Source file"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="12"
                                       FontWeight="Bold" />

                            <TextBlock Grid.Column="1"
                                       Text="Target file"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="12"
                                       FontWeight="Bold" />

                            <TextBlock Grid.Column="2"
                                       Text="Size"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="12"
                                       FontWeight="Bold" />

                            <TextBlock Grid.Column="3"
                                       Text="Status"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="12"
                                       FontWeight="Bold" />

                            <TextBlock Grid.Column="4"
                                       Text="Details"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="12"
                                       FontWeight="Bold" />
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="3">
                        <ItemsControl ItemsSource="{Binding RunItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:TransferRunItemRowViewModel">
                                    <Border Padding="10,6"
                                            BorderBrush="#252733"
                                            BorderThickness="0,0,0,1">

                                        <StackPanel Spacing="3">
                                            <Grid ColumnDefinitions="2*,2*,80,150,*"
                                                  ColumnSpacing="10">

                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding SourceFile}"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           ToolTip.Tip="{Binding SourceFile}"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis" />

                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding TargetFile}"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           ToolTip.Tip="{Binding TargetFile}"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis" />

                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding SizeDisplay}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource MutedTextBrush}" />

                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding Status}"
                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold" />

                                                <TextBlock Grid.Column="4"
                                                           Text="{Binding Error}"
                                                           Foreground="{StaticResource WarningBrush}"
                                                           FontSize="12"
                                                           TextWrapping="Wrap" />
                                            </Grid>

                                            <TextBlock Text="{Binding BackupDisplay}"
                                                       IsVisible="{Binding HasBackup}"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontSize="10"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
